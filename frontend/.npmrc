# Angular's @angular/build does a native dynamic import('@angular/compiler-cli').
# pnpm's default symlinked (isolated) node_modules layout isn't traversed by
# Node's native ESM resolver, causing "Cannot find package '@angular/compiler-cli'".
# A flat (hoisted) node_modules resolves this — same layout npm/yarn produce.
node-linker=hoisted
ignore-scripts=false
 