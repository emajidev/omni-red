# Conexión a Supabase Postgres.
# La conexión DIRECTA (db.<ref>.supabase.co) es IPv6-only; usa el POOLER IPv4.
PGHOST=aws-1-us-east-2.pooler.supabase.com
PGPORT=5432
PGUSER=postgres.<project-ref>
PGPASSWORD=tu-password-de-postgres
PGDATABASE=postgres

# Servidor
PORT=3000
CORS_ORIGIN=http://localhost:4200

# Credenciales de administrador (gate de "Cargar listas" OCR/CSV)
ADMIN_USER=admin
ADMIN_PASSWORD=$0m$0$unovzla
