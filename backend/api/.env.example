# Conexión a Supabase Postgres.
# La conexión DIRECTA (db.<ref>.supabase.co) es IPv6-only; usa el POOLER IPv4.
PGHOST=aws-1-us-east-2.pooler.supabase.com
PGPORT=5432
PGUSER=postgres.<project-ref>
PGPASSWORD=tu-password-de-postgres
PGDATABASE=postgres

# Servidor
PORT=3000
CORS_ORIGIN=http://localhost:4200

# Credenciales de administrador (gate de "Cargar listas" OCR/CSV)
ADMIN_USER=admin
ADMIN_PASSWORD=$0m$0$unovzla

# Registro médico EXTERNO (fvivemas) — fallback del buscador de personas.
# Lectura pública de Firestore (la apiKey es la pública del proyecto). Se
# mantiene server-side para no exponer la fuente en el cliente. En Railway,
# definir estas variables en el entorno del servicio.
FVIVEMAS_PROJECT_ID=asistencia-medica-fvivemas
FVIVEMAS_API_KEY=AIzaSyAc98GrjI9_OcdoPNg1OAwy_gOWWc0iTmw
FVIVEMAS_COLLECTION=medical_cases
