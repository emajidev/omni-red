# Conexión a Supabase Postgres.
# La conexión DIRECTA (db.<ref>.supabase.co) es IPv6-only; usa el POOLER IPv4.
PGHOST=aws-1-us-east-2.pooler.supabase.com
PGPORT=5432
PGUSER=postgres.<project-ref>
PGPASSWORD=tu-password-de-postgres
PGDATABASE=postgres

# Servidor
PORT=3000
CORS_ORIGIN=http://localhost:4200

# Credenciales de administrador (gate de "Cargar listas" OCR/CSV)
ADMIN_USER=admin
ADMIN_PASSWORD=$0m$0$unovzla

# Registro médico EXTERNO (fvivemas) — fallback del buscador de personas.
# Lectura pública de Firestore (la apiKey es la pública del proyecto). Se
# mantiene server-side para no exponer la fuente en el cliente. En Railway,
# definir estas variables en el entorno del servicio.
FVIVEMAS_PROJECT_ID=asistencia-medica-fvivemas
FVIVEMAS_API_KEY=AIzaSyAc98GrjI9_OcdoPNg1OAwy_gOWWc0iTmw
FVIVEMAS_COLLECTION=medical_cases

# Fuente EXTERNA "ayuda-api" — agregador (FastAPI) que indexa varias fuentes
# públicas de personas del terremoto. Se usa para buscar y para los totales
# (desaparecidos/encontrados). Sin endpoint de stats por estado: los totales se
# obtienen con un barrido cacheado de /api/search.
AYUDA_API_BASE=https://ayuda-api-551342186435.us-central1.run.app

# Fuente EXTERNA de EDIFICIOS dañados — mapa público de terremotovenezuela.com.
# Su SPA lee directo de su Supabase (PostgREST) con la clave *publishable*
# (solo lectura vía RLS). El backend la replica server-side y la vuelca en
# `edificios_caidos` (EdificiosSyncService → GET /rest/v1/buildings).
TERREMOTO_SUPABASE_URL=https://jckifxsdlnsvbztxydes.supabase.co
TERREMOTO_SUPABASE_KEY=sb_publishable_i7iEDrCVZcSt0k3RGFrY4g_WrtZBB4w
TERREMOTO_BUILDINGS_TABLE=buildings
# Auto-sync de edificios: intervalo (ms) y kill-switch.
EDIFICIOS_SYNC_INTERVAL_MS=300000
# EDIFICIOS_SYNC_DISABLED=true
